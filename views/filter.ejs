<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Filter Habits</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 20px;
        background: #f5f7fb;
        color: #1a1a1a;
      }
      nav a {
        margin-right: 14px;
        color: #1a73e8;
        text-decoration: none;
      }
      nav a:hover {
        text-decoration: underline;
      }
      .filter-card,
      table {
        width: 100%;
        margin-top: 14px;
      }
      .filter-card {
        background: white;
        padding: 18px;
        border: 1px solid #dcdfe6;
        border-radius: 8px;
      }
      select,
      button {
        padding: 10px;
        border-radius: 4px;
        border: 1px solid #cbd2d9;
      }
      button {
        background: #1a73e8;
        color: white;
        border: none;
        cursor: pointer;
        margin-left: 10px;
      }
      table {
        border-collapse: collapse;
        background: white;
      }
      th,
      td {
        border: 1px solid #dcdfe6;
        padding: 10px 12px;
        text-align: left;
      }
      th {
        background: #eef2f7;
      }
      .note {
        color: #555;
      }
      ul {
        margin: 0;
        padding-left: 18px;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>
    <header>
      <h1>Filter Habits</h1>
      <p class="note">Choose a category to see only the habits that belong to it.</p>
    </header>
    <div class="filter-card">
      <form method="GET" action="/filter">
        <label>
          Category
          <select name="category">
            <option value="">All categories</option>
            <% categories.forEach((category) => { %>
              <option value="<%= category %>" <%= selectedCategory === category ? 'selected' : '' %>><%= category %></option>
            <% }) %>
          </select>
        </label>
        <button type="submit">Apply filter</button>
      </form>
    </div>

    <% if (habits.length === 0) { %>
      <div class="note" style="margin-top:18px;">No habits found for this category.</div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Habit name</th>
            <th>Status</th>
            <th>Streak</th>
            <th>Description</th>
            <th>Category</th>
            <th>To-dos</th>
          </tr>
        </thead>
        <tbody>
          <% habits.forEach((habit) => { %>
            <tr>
              <td><%= habit.name %></td>
              <td><%= habit.done ? 'Done' : 'Pending' %></td>
              <td><%= habit.streak %></td>
              <td><%= habit.description %></td>
              <td><%= habit.category %></td>
              <td>
                <% if (habit.todos && habit.todos.length) { %>
                  <ul>
                    <% habit.todos.forEach((todo) => { %>
                      <li><%= todo %></li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <span class="note">No todos</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </body>
</html>
