<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habit Tracker</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 20px;
        background: #f5f7fb;
        color: #1a1a1a;
      }
      header {
        margin-bottom: 20px;
      }
      nav a {
        margin-right: 14px;
        color: #1a73e8;
        text-decoration: none;
      }
      nav a:hover {
        text-decoration: underline;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
        background: white;
      }
      th,
      td {
        border: 1px solid #dcdfe6;
        padding: 10px 12px;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #eef2f7;
      }
      button,
      input[type="submit"] {
        background: #1a73e8;
        color: white;
        border: none;
        padding: 8px 12px;
        cursor: pointer;
        border-radius: 4px;
      }
      button:hover,
      input[type="submit"]:hover {
        background: #155ab6;
      }
      .checkbox-form {
        display: inline-block;
      }
      .note {
        color: #555;
      }
      .empty-state {
        padding: 20px;
        text-align: center;
        color: #666;
      }
      .page-controls {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 14px;
        margin-bottom: 16px;
      }
      .page-controls select,
      .page-controls button {
        padding: 8px 10px;
        border: 1px solid #cbd2d9;
        border-radius: 4px;
      }
      .page-controls button {
        background: #1a73e8;
        color: white;
        border: none;
      }
      .page-controls button:hover {
        background: #155ab6;
      }
      ul {
        margin: 0;
        padding-left: 18px;
      }
    </style>
  </head>
  <body>
    <%- include('partials/navbar') %>
    <header>
      <h1>Habit Tracker</h1>
      <p class="note">Use the table below to track daily habits, update streaks, and delete completed goals.</p>
    </header>

    <div class="page-controls">
      <form method="GET" action="/">
        <label>
          Filter category:
          <select name="category">
            <option value="">All categories</option>
            <% categories.forEach((category) => { %>
              <option value="<%= category %>" <%= selectedCategory === category ? 'selected' : '' %>><%= category %></option>
            <% }) %>
          </select>
        </label>
        <button type="submit">Apply</button>
      </form>
    </div>

    <% if (habits.length === 0) { %>
      <div class="empty-state">
        <p>No habits yet. Add one from the Add Habit page.</p>
      </div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Habit name</th>
            <th>Status</th>
            <th>Streak</th>
            <th>Description</th>
            <th>Category</th>
            <th>To-dos</th>
            <th>Delete</th>
          </tr>
        </thead>
        <tbody>
          <% habits.forEach((habit) => { %>
            <tr>
              <td><%= habit.name %></td>
              <td>
                <form class="checkbox-form" method="POST" action="/toggle/<%= habit.id %>">
                  <label>
                    <input type="checkbox" name="done" onchange="this.form.submit()" <%= habit.done ? 'checked' : '' %> />
                    <span><%= habit.done ? 'Done' : 'Pending' %></span>
                  </label>
                </form>
              </td>
              <td><%= habit.streak %></td>
              <td><%= habit.description %></td>
              <td><%= habit.category %></td>
              <td>
                <% if (habit.todos && habit.todos.length) { %>
                  <ul>
                    <% habit.todos.forEach((todo) => { %>
                      <li><%= todo %></li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <span class="note">No todos</span>
                <% } %>
              </td>
              <td>
                <form method="POST" action="/delete/<%= habit.id %>" onsubmit="return confirm('Delete this habit?');">
                  <button type="submit">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </body>
</html>
